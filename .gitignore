# =============================================================================
# COMPREHENSIVE .gitignore FOR PRODUCTION
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT & SECRETS
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
.secrets
config/secrets.*
vault/

# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
package-lock.json.bak

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.eggs/
*.egg-info/
dist/
build/
*.egg
site-packages/
.pdm.toml
.pdm-python
pdm.lock
Pipfile.lock
poetry.lock
uv.lock

# -----------------------------------------------------------------------------
# BUILD OUTPUT & DIST
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
.cache/
public/build/
storybook-static/
.svelte-kit/
.astro/
.vercel/
.netlify/

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
log/
*.gz
*.bz2
npm-debug.log*
yarn-debug.log*
lerna-debug.log*
*.stderr
*.stdout

# -----------------------------------------------------------------------------
# DATABASES & DATA FILES
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.sql
*.dump
*.bak
dump.rdb
*.rdb
*.aof
data/
db/

# -----------------------------------------------------------------------------
# OS GENERATED FILES
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent


# -----------------------------------------------------------------------------
# EDITORS & IDEs
# -----------------------------------------------------------------------------

# VSCode
.vscode/
!.vscode/settings.json     # optional: share workspace settings
!.vscode/extensions.json   # optional: share recommended extensions
*.code-workspace

# -----------------------------------------------------------------------------
# TESTING & COVERAGE
# -----------------------------------------------------------------------------
coverage/
.coverage
.coverage.*
htmlcov/
*.lcov
.nyc_output/
.pytest_cache/
.jest-cache/
test-results/
test-reports/
junit.xml
*.spec.js.snap
__snapshots__/
playwright-report/
cypress/videos/
cypress/screenshots/
e2e/results/

# -----------------------------------------------------------------------------
# DOCKER & CONTAINERS
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml
.dockerignore.bak

# -----------------------------------------------------------------------------
# CLOUD & INFRASTRUCTURE
# -----------------------------------------------------------------------------

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Serverless Framework
.serverless/

# AWS
.aws/
aws-exports.js

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
firebase.json.bak

# Kubernetes
kubeconfig
*.kubeconfig
kube-config

# -----------------------------------------------------------------------------
# MEDIA & LARGE BINARY FILES
# -----------------------------------------------------------------------------
*.mp4
*.mp3
*.wav
*.flac
*.avi
*.mov
*.wmv
*.mkv
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.iso
*.dmg
*.exe
*.dll
*.so
*.dylib
*.psd
*.ai
*.sketch
*.fig

# -----------------------------------------------------------------------------
# DOCUMENTATION BUILD OUTPUT
# -----------------------------------------------------------------------------
docs/_build/
docs/build/
site/
_site/
.docusaurus/
.vuepress/dist/

# -----------------------------------------------------------------------------
# MONITORING & PROFILING
# -----------------------------------------------------------------------------
*.prof
*.heapsnapshot
*.heapdump
.clinic/
.0x/
flamegraph.html

# -----------------------------------------------------------------------------
# PACKAGE MANAGER METADATA (optional — adjust per project)
# -----------------------------------------------------------------------------
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# MISCELLANEOUS
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/
.history/
.changelog
CHANGELOG.md.bak
*.patch